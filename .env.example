# ─────────────────────────────────────────────────────────
# TrustChain Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Your wallet private key (WITHOUT the 0x prefix)
# Use a DEDICATED DEPLOYMENT WALLET — never your main wallet!
PRIVATE_KEY=your_private_key_here_without_0x

# Polygon Mumbai RPC URL
# Get a free endpoint from: https://www.alchemy.com or https://infura.io
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygon Mainnet RPC URL (production)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygonscan API key for contract verification
# Get from: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Deployed contract address (filled after deployment)
CONTRACT_ADDRESS=

# Optional: CoinMarketCap for gas cost reporting in USD
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
